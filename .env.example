# ===========================================
# Aham Portfolio - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ===========================================
# Database (Neon PostgreSQL)
# ===========================================
# Get your connection string from https://neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ===========================================
# Google Gemini AI
# ===========================================
# Get your API key from https://aistudio.google.com/apikey
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ===========================================
# Firebase (Client-side)
# ===========================================
# Get these from Firebase Console > Project Settings > General > Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ===========================================
# Firebase Admin (Server-side)
# ===========================================
# Get these from Firebase Console > Project Settings > Service Accounts
# Click "Generate new private key" and copy the values
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# Note: Keep the quotes and \n characters for the private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===========================================
# Vercel Blob Storage (for document uploads)
# ===========================================
# Get this from Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ===========================================
# Application URL
# ===========================================
# Used for CORS and redirects
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Security (for local admin creation)
# ===========================================
# Used for password hashing in scripts/create-admin.ts
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-for-password-hashing

# ===========================================
# Script Variables (only for running scripts)
# ===========================================
# These are NOT required for the app to run
# Only used when running utility scripts like create-admin.ts
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password-12chars
# ADMIN_NAME=Admin User
